{
  "name": "aether-explorer",
  "private": true,
  "version": "4.0.1",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "clean:release": "rm -rf dist src-tauri/target/release/bundle src-tauri/target/universal-apple-darwin/release/bundle",
    "lint": "npm run lint:ts && npm run lint:eslint",
    "lint:ts": "tsc --noEmit",
    "lint:eslint": "eslint .",
    "lint:readme": "node scripts/check-readme-sync.mjs",
    "lint:i18n": "node scripts/check-i18n-coverage.mjs",
    "lint:ci-gates": "node scripts/check-ci-gates.mjs",
    "lint:rust": "cd src-tauri && cargo clippy --lib -- -D warnings",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "cd src-tauri && cargo test --lib",
    "test:all": "npm test && npm run test:rust"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@vitejs/plugin-react": "^5.0.4",
    "i18next": "^26.0.10",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-i18next": "^17.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.1",
    "@types/node": "^22.14.0",
    "@vitest/ui": "^4.1.6",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.59.4",
    "vite": "^6.2.3",
    "vitest": "^4.1.6"
  }
}
