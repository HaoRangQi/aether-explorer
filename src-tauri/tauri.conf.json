{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Aether Explorer",
  "version": "0.2.1",
  "identifier": "com.aether.explorer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:41873",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Aether Explorer",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: http://localhost:* http://127.0.0.1:*; img-src 'self' tauri: asset: http: https: data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' tauri: 'unsafe-inline'; connect-src 'self' tauri: ipc: http://ipc.localhost http: https: ws: wss:; font-src 'self' data:; frame-src 'none'; object-src 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$DOWNLOAD/**",
          "$TEMP/**",
          "/Volumes/**",
          "/Applications/**",
          "/System/Applications/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0RUZFQThDNDczMTk4RDAKUldUUW1ERkhqT3J2TkVtMWU2S0gyZ2hqWXY4Ty9GWkxNY0g2UmY0Y3JEMEpBN2dNYWM5ME0xRjgK",
      "endpoints": [
        "https://github.com/HaoRangQi/aether-explorer/releases/download/stable/latest.json",
        "https://github.com/HaoRangQi/aether-explorer/releases/latest/download/latest.json"
      ]
    }
  }
}
