{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Aether Explorer",
  "version": "0.1.1-draft",
  "identifier": "com.aether.explorer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Aether Explorer",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$DOWNLOAD/**",
          "$TEMP/**",
          "/Volumes/**",
          "/Applications/**",
          "/System/Applications/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCRkMxNUU5MjE2OEY4M0MKUldROCtHZ2g2Ulg4SzgxVk9pR1NhZytlRlJQUktuTG9uYlRONWJROTRYOGV3RjlMdGxnZm5VSEUK",
      "endpoints": [
        "https://github.com/HaoRangQi/aether-explorer/releases/latest/download/latest.json"
      ]
    }
  }
}
